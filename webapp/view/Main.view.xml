<mvc:View
	controllerName="beamsuntoryinc.createcustomerform.controller.Main"
	displayBlock="true"
	xmlns="sap.uxap"
	xmlns:m="sap.m"
	xmlns:blocks="beamsuntoryinc.createcustomerform.controller.blocks"
	xmlns:mvc="sap.ui.core.mvc"
	xmlns:core="sap.ui.core"
	core:require="{
		formatter: 'beamsuntoryinc/createcustomerform/model/formatter'
	}">
	<m:Page showHeader="false">
		<m:Wizard id="Wizard" complete="onWizardCompleted">
			<m:WizardStep title="{i18n>lblSectionOrganizational}">
				<core:Fragment
					fragmentName="beamsuntoryinc.createcustomerform.view.fragments.Organizational"
					type="XML"/>
			</m:WizardStep>
			<m:WizardStep title="{i18n>lblSectionGeneral}">
				<core:Fragment
					fragmentName="beamsuntoryinc.createcustomerform.view.fragments.General"
					type="XML"/>
				<core:Fragment
					fragmentName="beamsuntoryinc.createcustomerform.view.fragments.CustomerAttributes"
					type="XML"/>
				<core:Fragment
					fragmentName="beamsuntoryinc.createcustomerform.view.fragments.TaxInformation"
					type="XML"/>
			</m:WizardStep>
			<m:WizardStep title="{i18n>lblSectionAddress}">
				<core:Fragment
					fragmentName="beamsuntoryinc.createcustomerform.view.fragments.Address"
					type="XML"/>
				<core:Fragment
					fragmentName="beamsuntoryinc.createcustomerform.view.fragments.CustomerContact"
					type="XML"/>
			</m:WizardStep>
			<m:WizardStep title="{i18n>lblSectionSales}">
				<core:Fragment
					fragmentName="beamsuntoryinc.createcustomerform.view.fragments.Sales"
					type="XML"/>
			</m:WizardStep>
			<m:WizardStep title="{i18n>lblSectionAccountManager}">
				<core:Fragment
					fragmentName="beamsuntoryinc.createcustomerform.view.fragments.AccountManager"
					type="XML"/>
			</m:WizardStep>
		</m:Wizard>
	</m:Page>
</mvc:View>
