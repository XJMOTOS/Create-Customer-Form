<core:FragmentDefinition
	xmlns:mvc="sap.ui.core.mvc"
	xmlns:core="sap.ui.core"
	xmlns:forms="sap.ui.layout.form"
	xmlns="sap.m">
	<OverflowToolbar>
		<content>
			<Title text="{i18n>lblSectionTaxInformation}"/>
			<ToolbarSpacer />
			<Button
				icon="sap-icon://add"
				press=".onAddContact"
				visible="{view>/show/table/customerContact}"/>
			<Button
				text="{= ${view>/show/table/customerContact} ? ${i18n>buttonHide} : ${i18n>buttonShow} }"
				press=".onToggleCustomerContactTable"/>
		</content>
	</OverflowToolbar>
	<Table 
		mode="Delete"
		delete=".onRemoveContact"
		items="{customerContact>/}"
		visible="{view>/show/table/customerContact}">
		<columns>
			<Column>
				<Text text="{i18n>columnContactType}"/>
			</Column>
			<Column>
				<Text text="{i18n>columnName}"/>
			</Column>
			<Column>
				<Text text="{i18n>columnSurname}"/>
			</Column>
			<Column>
				<Text text="{i18n>columnPhone}"/>
			</Column>
			<Column>
				<Text text="{i18n>columnFax}"/>
			</Column>
			<Column>
				<Text text="{i18n>columnEmail}"/>
			</Column>
		</columns>
		<items>
			<ColumnListItem>
				<cells>
					<Select
						selectedKey="{customerContact>contactType}"
						forceSelection="false"
						items="{ path: 'contactType>/', templateShareable: false }">
						<core:Item key="{contactType>key}" text="{contactType>key}"/>
					</Select>
					<Input value="{customerContact>name}"/>
					<Input value="{customerContact>surname}"/>
					<Input value="{customerContact>phone}"/>
					<Input value="{customerContact>fax}"/>
					<Input value="{customerContact>email}"/>
				</cells>
			</ColumnListItem>
		</items>
	</Table>
</core:FragmentDefinition>
