<core:FragmentDefinition
	xmlns:mvc="sap.ui.core.mvc"
	xmlns:core="sap.ui.core"
	xmlns:forms="sap.ui.layout.form"
	xmlns="sap.m">
	<forms:SimpleForm
		labelSpanXL="4" labelSpanL="3" labelSpanM="4" labelSpanS="12"
		emptySpanXL="0" emptySpanL="4" emptySpanM="0" emptySpanS="0"
		columnsXL="2" columnsL="1" columnsM="1"
		editable="false"
		layout="ResponsiveGridLayout"
		adjustLabelSpan="false"
		singleContainerFullSize="false">
		<Label text="{i18n>lblName} 2"/>
		<Input/>
		<Label text="{i18n>lblCity}" required="true"/>
		<Input
			value="{customer>/AddressSet/City}"
			valueState="{= ${customer>AddressSet/City} ? 'None' : 'Error' }"/>
		<Label text="{i18n>lblTelephone}"/>
		<Input/>
		<Label text="{i18n>lblName} 3"/>
		<Input/>
		<Label text="{i18n>lblPOBox}"/>
		<Input/>
		<Label text="{i18n>lblStreet} 2"/>
		<Input/>
		<Label text="{i18n>lblStreet} 5"/>
		<Input/>
		<Label text="{i18n>lblRoom}"/>
		<Input/>

		<Label text="{i18n>lblCountry}" required="true"/>
		<Select
			forceSelection="false"
			selectedKey="{customer>/AddressSet/Country}"
			valueState="{= ${customer>/AddressSet/Country} ? 'None' : 'Error' }">
		</Select>
		<Label text="{i18n>lblStreetAndHouseNumber}" required="true"/>
		<Input
			value="{customer>/AddressSet/StreetNo}"
			valueState="{= ${customer>AddressSet/StreetNo} ? 'None' : 'Error' }"/>
		<Label text="{i18n>lblFax}"/>
		<Input/>
		<Label text="{i18n>lblName} 4"/>
		<Input/>
		<Label text="{i18n>lblHouseNumber}"/>
		<Input/>
		<Label text="{i18n>lblStreet} 3"/>
		<Input/>
		<Label text="{i18n>lblBuilding}"/>
		<Input/>
		<Label text=""/>
		<Text/>

		<Label text="{i18n>lblRegion}"/>
		<Select forceSelection="false">
		</Select>
		<Label text="{i18n>lblTransportationZone}" required="true"/>
		<Select
			forceSelection="false"
			selectedKey="{customer>/AddressSet/Transpzone}"
			valueState="{= ${customer>/AddressSet/Transpzone} ? 'None' : 'Error' }">
		</Select>
		<Label text="{i18n>lblPostalCode}" required="true"/>
		<Input
			value="{customer>/AddressSet/PostlCod1}"
			valueState="{= ${customer>AddressSet/PostlCod1} ? 'None' : 'Error' }"/>
		<Label text="{i18n>lblEmail}"/>
		<Input/>
		<Label text="{i18n>lblDistrict}"/>
		<Input/>
		<Label text="{i18n>lblStreet}"/>
		<Input/>
		<Label text="{i18n>lblStreet} 4"/>
		<Input/>
		<Label text="{i18n>lblFloor}"/>
		<Input/>
	</forms:SimpleForm>
</core:FragmentDefinition>
