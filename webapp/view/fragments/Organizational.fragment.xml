<core:FragmentDefinition
	xmlns="sap.m"
	xmlns:core="sap.ui.core"
	xmlns:forms="sap.ui.layout.form">
	<forms:SimpleForm
		labelSpanXL="4" labelSpanL="3" labelSpanM="4" labelSpanS="12"
		emptySpanXL="0" emptySpanL="4" emptySpanM="0" emptySpanS="0"
		columnsXL="2" columnsL="1" columnsM="1"
		editable="false"
		layout="ResponsiveGridLayout"
		adjustLabelSpan="false"
		singleContainerFullSize="false">
		<forms:content>
			<Toolbar>
				<ToolbarSpacer/>
				<Button
					text="{= ${view>/show/optionalOrganizationalDataFields} ? ${i18n>buttonHideOptionalFields} : ${i18n>buttonShowOptionalFields} }"
					press=".onToggleOrganizationalDataOptionalFields"/>
			</Toolbar>
			<Label text="{i18n>lblAccountGroup}" required="true" class="sapUiTinyMarginTop"/>
			<Select
				forceSelection="true"
				selectedKey="{customer>/Ktokd}"
				items=""
				valueState="{= ${customer>/Ktokd} ? 'None' : 'Error' }"
				class="sapUiBigMarginEnd">
				<core:Item key="{Id}" text="{Name}"/>
			</Select>
			<Label text="{i18n>lblCompanyCode}" required="true" class="sapUiTinyMarginTop"/>
			<Select
				forceSelection="true"
				selectedKey="{customer>/Bukrs}"
				valueState="{= ${customer>/Bukrs} ? 'None' : 'Error' }">
			</Select>
			<Label text="{i18n>lblSalesOrganization}" required="true" class="sapUiTinyMarginTop"/>
			<Select
				forceSelection="true"
				selectedKey="{customer>/Vkorg}"
				valueState="{= ${customer>/Vkorg} ? 'None' : 'Error' }">
			</Select>
			<Label text="{i18n>lblRequestedBy}" class="sapUiTinyMarginTop" visible="{view>/show/optionalOrganizationalDataFields}"/>
			<Text text="...@domain.com" class="sapUiTinyMarginTopBottom" visible="{view>/show/optionalOrganizationalDataFields}"/>
			<Label text="{i18n>lblTaxNumber}" class="sapUiTinyMarginTop" visible="{view>/show/optionalOrganizationalDataFields}"/>
			<!-- TODO: Wrong binding field -->
			<Input
				value="{customer>/Stcd1}"
				valueState="{= ${customer>/Stcd1} ? 'None' : 'Error' }"
				visible="{view>/show/optionalOrganizationalDataFields}"/>

			<Label text="{i18n>lblDistributionChannel}" required="true" class="sapUiTinyMarginTop"/>
			<Select
				forceSelection="false"
				selectedKey="{customer>/Vtweg}"
				items="{distributtionChannel>/}"
				valueState="{= ${customer>/Vtweg} ? 'None' : 'Error' }">
				<core:Item key="{distributtionChannel>key}" text="{distributtionChannel>text}"/>
			</Select>
			<Label text="{i18n>lblRequestedDate}" class="sapUiTinyMarginTop" visible="{view>/show/optionalOrganizationalDataFields}"/>
			<DatePicker
				placeholder=" "
				value="{
						'path':'/requestedDate',
						'type':'sap.ui.model.type.Date',
						'formatOptions': {
							'pattern': 'dd/MM/yyyy'
						}
					}"
				visible="{view>/show/optionalOrganizationalDataFields}"/>
			<Label text="{i18n>lblTaxRegistration}" class="sapUiTinyMarginTop" visible="{view>/show/optionalOrganizationalDataFields}"/>
			<Input
				value="{customer>/Stceg}"
				valueState="{= ${customer>/Stceg} ? 'None' : 'Error' }"
				visible="{view>/show/optionalOrganizationalDataFields}"/>

			<Label text="{i18n>lblDivision}" required="true" class="sapUiTinyMarginTop"/>
			<Select
				forceSelection="false"
				selectedKey="{customer>/division}"
				items="{division>/}">
				<core:Item key="{division>key}" text="{division>text}"/>
			</Select>
		</forms:content>
	</forms:SimpleForm>
</core:FragmentDefinition>
