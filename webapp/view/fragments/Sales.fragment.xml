			valueState="{= ${customer>/Vsbed} ? 'None' : 'Error' }">
		</Select>
		<Label text="{i18n>lblCustomerDeliveryBlock}" required="true"/>
		<Input
			value="{customer>/Lifsd}"
			valueState="{= ${customer>/Lifsd} ? 'None' : 'Error' }"/>
		<Label text=""/>
		<CheckBox text="{i18n>lblPartialDelivery}" selected="true" class="sapUiTinyMarginTopBottom"/>
