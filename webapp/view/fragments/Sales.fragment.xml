			forceSelection="false"
			selectedKey="{customer>/Ktgrd}"
			items="{ path: 'accountAssignmentGroup>/' }"
			valueState="{= ${customer>/Ktgrd} ? 'None' : 'Error' }">
			<core:Item key="{accountAssignmentGroup>key}" text="{accountAssignmentGroup>text}"/>
