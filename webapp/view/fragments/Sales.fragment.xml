		<Input/>
		<Label text="{i18n>lblCustomerGroup} 9"/>
		<Input/>
		<Label text="{i18n>lblCustomerGroup} 12"/>
		<Input/>
		<Label text="{i18n>lblCustomerGroup} 15"/>
		<Input/>
		<Label text="{i18n>lblCustomerGroup} 18"/>
		<Input/>

		<Label text="{i18n>lblSalesOffice}"/>
