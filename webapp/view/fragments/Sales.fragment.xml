		<Input/>
		<Label text="{i18n>lblDeliveringPlant}"/>
		<Input/>
		<Label text="{i18n>lblCustomerGroup} 7"/>
		<Select></Select>
		<Label text="{i18n>lblCustomerGroup} 10"/>
		<Select></Select>
		<Label text="{i18n>lblCustomerGroup} 13"/>
		<Select></Select>
		<Label text="{i18n>lblCustomerGroup} 16"/>
