<core:FragmentDefinition
	xmlns="sap.m"
	xmlns:mvc="sap.ui.core.mvc"
	xmlns:core="sap.ui.core"
	xmlns:forms="sap.ui.layout.form"
	xmlns:microchart="sap.suite.ui.microchart">
	<forms:SimpleForm
		labelSpanXL="4" labelSpanL="3" labelSpanM="4" labelSpanS="12"
		emptySpanXL="0" emptySpanL="4" emptySpanM="0" emptySpanS="0"
		columnsXL="2" columnsL="1" columnsM="1"
		editable="false"
		layout="ResponsiveGridLayout"
		adjustLabelSpan="false"
		singleContainerFullSize="false">
		<forms:toolbar>
			<Toolbar>
				<ToolbarSpacer/>
				<microchart:HarveyBallMicroChart size="XS"
						total="100" showFractions="true" >
					<microchart:items>
						<microchart:HarveyBallMicroChartItem fraction="49" color="Good" fractionScale="%"/>
					</microchart:items>
				</microchart:HarveyBallMicroChart>
				<Button
					text="{= ${view>/show/companyFields} ? ${i18n>buttonHideCompanyFields} : ${i18n>buttonShowCompanyFields} }"
					press=".onToggleCompanyFields"/>
			</Toolbar>
		</forms:toolbar>
		<forms:content>
			<Label	
				text="{i18n>lblSortKey}"
				class="sapUiTinyMarginTop"/>
			<HBox>
				<core:Icon
					src="sap-icon://hint"
					decorative="false"
					class="sapUiTinyMarginTop sapUiTinyMarginEnd"
					tooltip="{i18n>tooltipSortKey}">
					<core:layoutData>
						<FlexItemData growFactor="0"/>
					</core:layoutData>
				</core:Icon>
				<Select
					forceSelection="false"
					selectedKey="{customer>/company/sortKey}"
					items="{sortKeys>/}"
					width="100%">
					<core:Item key="{sortKeys>key}" text="{sortKeys>text}"/>
					<layoutData>
						<FlexItemData growFactor="1"/>
					</layoutData>
				</Select>
			</HBox>
			
			<Label	
				text="{i18n>lblReconciliationAccount}"
				class="sapUiTinyMarginTop"/>
			<HBox>
				<core:Icon
					src="sap-icon://hint"
					decorative="false"
					class="sapUiTinyMarginTop sapUiTinyMarginEnd"
					tooltip="{i18n>tooltipReconciliationAccount}">
					<core:layoutData>
						<FlexItemData growFactor="0"/>
					</core:layoutData>
				</core:Icon>
				<Select
					forceSelection="false"
					selectedKey="{customer>/company/reconciliationAccount}"
					items="{reconciliationAccounts>/}"
					width="100%">
					<core:Item key="{reconciliationAccounts>key}" text="{reconciliationAccounts>text}"/>
					<layoutData>
						<FlexItemData growFactor="1"/>
					</layoutData>
				</Select>
			</HBox>

			<Label	
				text="{i18n>lblAuthorizationGroup}"
				class="sapUiTinyMarginTop"
				visible="{view>/show/companyFields}"/>
			<HBox visible="{view>/show/companyFields}">
				<core:Icon
					src="sap-icon://hint"
					decorative="false"
					class="sapUiTinyMarginTop sapUiTinyMarginEnd"
					tooltip="{i18n>tooltipAuthorizationGroup}">
					<core:layoutData>
						<FlexItemData growFactor="0"/>
					</core:layoutData>
				</core:Icon>
				<Input
					value="{customer>/company/authorizationGroup}">
					<layoutData>
						<FlexItemData growFactor="1"/>
					</layoutData>
				</Input>
			</HBox>

			<Label	
				text="{i18n>lblCashManagmentGroup}"
				class="sapUiTinyMarginTop"/>
			<HBox>
				<core:Icon
					src="sap-icon://hint"
					decorative="false"
					class="sapUiTinyMarginTop sapUiTinyMarginEnd"
					tooltip="{i18n>tooltipCashManagmentGroup}">
					<core:layoutData>
						<FlexItemData growFactor="0"/>
					</core:layoutData>
				</core:Icon>
				<Select
					forceSelection="false"
					selectedKey="{customer>/company/cashManagmentGroup}"
					items="{cashManagmentGroups>/}"
					width="100%">
					<core:Item key="{cashManagmentGroups>key}" text="{cashManagmentGroups>text}"/>
					<layoutData>
						<FlexItemData growFactor="1"/>
					</layoutData>
				</Select>
			</HBox>

			<Label	
				text="{i18n>lblToleranceGroup}"
				class="sapUiTinyMarginTop"/>
			<HBox>
				<core:Icon
					src="sap-icon://hint"
					decorative="false"
					class="sapUiTinyMarginTop sapUiTinyMarginEnd"
					tooltip="{i18n>tooltipToleranceGroup}">
					<core:layoutData>
						<FlexItemData growFactor="0"/>
					</core:layoutData>
				</core:Icon>
				<Select
					forceSelection="false"
					selectedKey="{customer>/company/toleranceGroup}"
					items="{toleranceGroups>/}"
					width="100%">
					<core:Item key="{toleranceGroups>key}" text="{toleranceGroups>text}"/>
					<layoutData>
						<FlexItemData growFactor="1"/>
					</layoutData>
				</Select>
			</HBox>

			<Label	
				text="{i18n>lblPaymentMethod}"
				class="sapUiTinyMarginTop"/>
			<HBox>
				<core:Icon
					src="sap-icon://hint"
					decorative="false"
					class="sapUiTinyMarginTop sapUiTinyMarginEnd"
					tooltip="{i18n>tooltipPaymentMethod}">
					<core:layoutData>
						<FlexItemData growFactor="0"/>
					</core:layoutData>
				</core:Icon>
				<Select
					forceSelection="false"
					selectedKey="{customer>/company/paymentMethod}"
					items="{paymentMethods>/}"
					width="100%">
					<core:Item key="{oaymentMethods>key}" text="{paymentMethods>text}"/>
					<layoutData>
						<FlexItemData growFactor="1"/>
					</layoutData>
				</Select>
			</HBox>

			<Label
				text="{i18n>lblHouseBank}"
				class="sapUiTinyMarginTop"
				visible="{view>/show/companyFields}"/>
			<HBox visible="{view>/show/companyFields}">
				<core:Icon
					src="sap-icon://hint"
					decorative="false"
					class="sapUiTinyMarginTop sapUiTinyMarginEnd"
					tooltip="{i18n>tooltipHouseBank}">
					<core:layoutData>
						<FlexItemData growFactor="0"/>
					</core:layoutData>
				</core:Icon>
				<Input
					value="{customer>/company/houseBank}">
					<layoutData>
						<FlexItemData growFactor="1"/>
					</layoutData>
				</Input>
			</HBox>

			<Label
				text="{i18n>lblAccountingClerkAbbreviation}"
				class="sapUiTinyMarginTop"
				visible="{view>/show/companyFields}"/>
			<HBox visible="{view>/show/companyFields}">
				<core:Icon
					src="sap-icon://hint"
					decorative="false"
					class="sapUiTinyMarginTop sapUiTinyMarginEnd"
					tooltip="{i18n>tooltipAccountingClerkAbbreviation}">
					<core:layoutData>
						<FlexItemData growFactor="0"/>
					</core:layoutData>
				</core:Icon>
				<Input
					value="{customer>/company/accountingClerkAbbreviation}">
					<layoutData>
						<FlexItemData growFactor="1"/>
					</layoutData>
				</Input>
			</HBox>

		</forms:content>
	</forms:SimpleForm>
</core:FragmentDefinition>
