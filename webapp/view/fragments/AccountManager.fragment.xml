<core:FragmentDefinition
	xmlns:mvc="sap.ui.core.mvc"
	xmlns:core="sap.ui.core"
	xmlns:forms="sap.ui.layout.form"
	xmlns="sap.m">
	<forms:SimpleForm
		labelSpanXL="4" labelSpanL="3" labelSpanM="4" labelSpanS="12"
		emptySpanXL="0" emptySpanL="4" emptySpanM="0" emptySpanS="0"
		columnsXL="2" columnsL="1" columnsM="1"
		editable="false"
		layout="ResponsiveGridLayout"
		adjustLabelSpan="false"
		singleContainerFullSize="false">
		<core:Title text=" "/>
		<Label text="{i18n>lblKeyOfSorting}" required="true"/>
		<Input
			value="{customer>/Zuawa}"
			valueState="{= ${customer>/Zuawa} ? 'None' : 'Error' }"/>
		<Label text="{i18n>lblCashMgmtGrp}"/>
		<Input/>
		<Label text="{i18n>lblHouseBank}"/>
		<Input/>

		<Label text="{i18n>lblRenconciliationAccount}" required="true"/>
		<Input
			value="{customer>/Akont}"
			valueState="{= ${customer>/Akont} ? 'None' : 'Error' }"/>
		<Label text="{i18n>lblToleranceGroup}"/>
		<Input/>
		<Label text="{i18n>lblAccountingClerk}"/>
		<Input/>

		<Label text="{i18n>lblAuthorizationGroup}" required="true"/>
		<Input
			value="{customer>/Begru}"
			valueState="{= ${customer>/Begru} ? 'None' : 'Error' }"/>
		<Label text="{i18n>lblPaymentMethods}"/>
		<Select
			forceSelection="false"
			selectedKey="{customer>/paymentTerms}"
			items="{ path: 'paymentTerms>/' }">
			<core:Item key="{paymentTerms>key}" text="{paymentTerms>text}"/>
		</Select>
	</forms:SimpleForm>

	<forms:SimpleForm
		labelSpanXL="4" labelSpanL="3" labelSpanM="4" labelSpanS="12"
		emptySpanXL="0" emptySpanL="4" emptySpanM="0" emptySpanS="0"
		columnsXL="2" columnsL="1" columnsM="1"
		editable="false"
		layout="ResponsiveGridLayout"
		adjustLabelSpan="false"
		singleContainerFullSize="false">
		<core:Title text="{i18n>lblHierarchyType} A"/>
		<Label text="{i18n>lblLevel} 1"/>
		<Select></Select>
		<Label text="{i18n>lblLevel} 2"/>
		<Select></Select>
		<Label text="{i18n>lblLevel} 3"/>
		<Select></Select>
		<Label text="{i18n>lblLevel} 4"/>
		<Select></Select>

		<core:Title text="{i18n>lblHierarchyType} B"/>
		<Label text="{i18n>lblLevel} 1"/>
		<Select></Select>
		<Label text="{i18n>lblLevel} 2"/>
		<Select></Select>
		<Label text="{i18n>lblLevel} 3"/>
		<Select></Select>
		<Label text="{i18n>lblLevel} 4"/>
		<Select></Select>
		<Label text="{i18n>lblLevel} 5"/>
		<Select></Select>
		<Label text="{i18n>lblLevel} 6"/>
		<Select></Select>
	</forms:SimpleForm>
</core:FragmentDefinition>
