<core:FragmentDefinition
	xmlns:mvc="sap.ui.core.mvc"
	xmlns:core="sap.ui.core"
	xmlns:forms="sap.ui.layout.form"
	xmlns="sap.m">
	<VBox 
		visible="{view>/show/optionalGeneralDataFields}">
	<OverflowToolbar >
		<content>
			<Title text="{i18n>lblSectionTaxInformation}"/>
			<ToolbarSpacer />
			<Button
				text="{= ${view>/show/table/taxInformation} ? ${i18n>buttonHide} : ${i18n>buttonShow} }"
				press=".onToggleTaxTable"/>
		</content>
	</OverflowToolbar>
	<Table 
		mode="None"
		items="{taxInformation>/}"
		visible="{view>/show/table/taxInformation}">
		<columns>
			<Column>
				<Text text="{i18n>columnTaxCountry}"/>
			</Column>
			<Column>
				<Text text="{i18n>columnTaxCategory}"/>
			</Column>
			<Column>
				<Text text="{i18n>columnTaxClassification}"/>
			</Column>
		</columns>
		<items>
			<ColumnListItem>
				<cells>
					<Input value="{taxInformation>taxCountry}"/>
					<Input value="{taxInformation>taxCategory}"/>
					<Select
						selectedKey="{taxInformation>taxClassification}"
						items="{ path: 'taxClasification>/', templateShareable: false }">
						<core:Item key="{taxClasification>key}" text="{taxClasification>text}"/>
					</Select>
					<Input value="{taxInformation>taxClassification}"/>
				</cells>
			</ColumnListItem>
		</items>
	</Table>
	</VBox>
</core:FragmentDefinition>
