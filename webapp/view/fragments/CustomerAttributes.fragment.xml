<core:FragmentDefinition
	xmlns:mvc="sap.ui.core.mvc"
	xmlns:core="sap.ui.core"
	xmlns:forms="sap.ui.layout.form"
	xmlns="sap.m">
	<forms:SimpleForm
		labelSpanXL="4" labelSpanL="3" labelSpanM="4" labelSpanS="12"
		emptySpanXL="0" emptySpanL="4" emptySpanM="0" emptySpanS="0"
		columnsXL="2" columnsL="1" columnsM="1"
		editable="false"
		layout="ResponsiveGridLayout"
		adjustLabelSpan="false"
		singleContainerFullSize="false"
		title="{i18n>lblSectionCustomerAttributes}"
		visible="{view>/show/optionalGeneralDataFields}">
		<Label text="{i18n>lblAttribute} 1"/>
		<Select forceSelection="true"></Select>
		<Label text="{i18n>lblAttribute} 2"/>
		<Select forceSelection="true"></Select>
		<Label text="{i18n>lblAttribute} 3"/>
		<Select forceSelection="true"></Select>
		<Label text="{i18n>lblAttribute} 4"/>
		<Select forceSelection="true"></Select>
		<Label text="{i18n>lblAttribute} 5"/>
		<Select forceSelection="true"></Select>
		<Label text="{i18n>lblAttribute} 6"/>
		<Select forceSelection="true"></Select>
		<Label text="{i18n>lblAttribute} 7"/>
		<Select forceSelection="true"></Select>
		<Label text="{i18n>lblAttribute} 8"/>
		<Select forceSelection="true"></Select>
		<Label text="{i18n>lblAttribute} 9"/>
		<Select forceSelection="true"></Select>
		<Label text="{i18n>lblAttribute} 10"/>
		<Select forceSelection="true"></Select>
	</forms:SimpleForm>
</core:FragmentDefinition>
