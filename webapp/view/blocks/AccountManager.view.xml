<mvc:View controllerName="beamsuntoryinc.createcustomerform.controller.blocks.General"
	xmlns:mvc="sap.ui.core.mvc"
	xmlns:core="sap.ui.core"
	xmlns:forms="sap.ui.layout.form"
	xmlns="sap.m">
	<VBox>
		<forms:SimpleForm
			labelSpanXL="12" labelSpanL="12" labelSpanM="12" labelSpanS="12"
			columnsXL="3" columnsL="3" columnsM="3"
			editable="false"
			layout="ResponsiveGridLayout">
			<forms:content>
				<core:Title text=" "/>
				<Label text="{i18n>lblKeyOfSorting}" required="true"/>
				<Input/>
				<Label text="{i18n>lblCashMgmtGrp}"/>
				<Input/>
				<Label text="{i18n>lblHouseBank}"/>
				<Input/>

				<core:Title text=""/>
				<Label text="{i18n>lblRenconciliationAccount}" required="true"/>
				<Input/>
				<Label text="{i18n>lblToleranceGroup}"/>
				<Input/>
				<Label text="{i18n>lblAccountingClerk}"/>
				<Input/>

				<core:Title text=""/>
				<Label text="{i18n>lblAuthorizationGroup}" required="true"/>
				<Input/>
				<Label text="{i18n>lblPaymentMethods}"/>
				<Select
					forceSelection="false"
					selectedKey="{customer>/paymentTerms}"
					items="{ path: 'paymentTerms>/' }">
					<core:Item key="{paymentTerms>key}" text="{paymentTerms>text}"/>
				</Select>
			</forms:content>
		</forms:SimpleForm>

		<forms:SimpleForm
			labelSpanXL="12" labelSpanL="12" labelSpanM="12" labelSpanS="12"
			columnsXL="2" columnsL="2" columnsM="2"
			editable="false"
			layout="ResponsiveGridLayout">
			<forms:content>
				<core:Title text="{i18n>lblHierarchyType} A"/>
				<Label text="{i18n>lblLevel} 1"/>
				<Select></Select>
				<Label text="{i18n>lblLevel} 2"/>
				<Select></Select>
				<Label text="{i18n>lblLevel} 3"/>
				<Select></Select>
				<Label text="{i18n>lblLevel} 4"/>
				<Select></Select>

				<core:Title text="{i18n>lblHierarchyType} B"/>
				<Label text="{i18n>lblLevel} 1"/>
				<Select></Select>
				<Label text="{i18n>lblLevel} 2"/>
				<Select></Select>
				<Label text="{i18n>lblLevel} 3"/>
				<Select></Select>
				<Label text="{i18n>lblLevel} 4"/>
				<Select></Select>
				<Label text="{i18n>lblLevel} 5"/>
				<Select></Select>
				<Label text="{i18n>lblLevel} 6"/>
				<Select></Select>
			</forms:content>
		</forms:SimpleForm>
	</VBox>
</mvc:View>
