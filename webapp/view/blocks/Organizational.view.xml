<mvc:View controllerName="beamsuntoryinc.createcustomerform.controller.blocks.Organizational"
	xmlns:mvc="sap.ui.core.mvc"
	xmlns:core="sap.ui.core"
	xmlns:forms="sap.ui.layout.form"
	xmlns="sap.m">
	<forms:SimpleForm
		labelSpanL="3" labelSpanM="3" labelSpanS="3"
		emptySpanL="0" emptySpanM="0" emptySpanS="0"
		editable="false"
		maxContainerCols="3"
		layout="ResponsiveGridLayout"
		width="100%">
		<Label text="{i18n>lblAccountGroup}" required="true"/>
		<Select
			forceSelection="true"
			selectedKey="{/accountGroup}"
			items="{
				path: '/accountGroups'
			}">
			<core:Item key="{Id}" text="{Name}" />
		</Select>
		<Label text="{i18n>lblCompanyCode}" required="true"/>
		<Select forceSelection="true">
		</Select>
		<Label text="{i18n>lblSalesOrganization}" required="true"/>
		<Select forceSelection="true">
		</Select>
		<Label text="{i18n>lblDistributionChannel}" required="true"/>
		<Select
			forceSelection="false"
			selectedKey="{customer>/distributtionChannel}"
			items="{ path: 'distributtionChannel>/' }">
			<core:Item key="{distributtionChannel>key}" text="{distributtionChannel>text}"/>
		</Select>

		<Label text="{i18n>lblDivision}" required="true"/>
		<Select
			forceSelection="false"
			selectedKey="{customer>/division}"
			items="{ path: 'division>/' }">
			<core:Item key="{division>key}" text="{division>text}"/>
		</Select>
		<Label text="{i18n>lblRequestedBy}"/>
		<Input/>
		<Label text="{i18n>lblRequestedDate}"/>
		<DatePicker
			placeholder=" "
			value="{
					'path':'/requestedDate',
					'type':'sap.ui.model.type.Date',
					'formatOptions': {
						'pattern': 'dd/MM/yyyy'
					}
				}"/>
		<Label text="{i18n>lblTaxNumber}"/>
		<Input/>
		<Label text="{i18n>lblTaxRegistration}"/>
		<Input/>
	</forms:SimpleForm>
</mvc:View>
